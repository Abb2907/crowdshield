{
  "name": "crowdcommand-workspace",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "backend",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:backend": "npm run dev --workspace=backend",
    "install:all": "npm install",
    "build": "npm run build --workspace=backend",
    "start": "node backend/dist/index.js"
  }
}